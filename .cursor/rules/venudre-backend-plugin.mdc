### Translatable Entity Service (CRUD methods)

For entities that use translations - requires `TranslatorService` and `TranslatableSaver`:

#### findAll (List with pagination)

```typescript
async findAll(ctx: RequestContext, options?: MyEntityListOptions) {
    return this.listQueryBuilder
        .build(MyEntity, options, {
            ctx,
            channelId: ctx.channelId,          // Only if ChannelAware
            where: { deletedAt: IsNull() },    // Only if soft-deletable
        })
        .getManyAndCount()
        .then(([items, totalItems]) => ({
            items: items.map(item => this.translator.translate(item, ctx)),
            totalItems,
        }));
}
```

#### findOne

```typescript
// Option A: Return undefined when not found (let caller handle)
async findOne(ctx: RequestContext, id: ID) {
    return this.connection
        .findOneInChannel(ctx, MyEntity, id, ctx.channelId, {
            where: { deletedAt: IsNull() },
        })
        .then(entity => entity && this.translator.translate(entity, ctx));
}

// Option B: Throw EntityNotFoundError when not found
async findOneOrThrow(ctx: RequestContext, id: ID) {
    const entity = await this.connection
        .getRepository(ctx, MyEntity)
        .findOne({ where: { id, deletedAt: IsNull() } });
    if (!entity) {
        throw new EntityNotFoundError('MyEntity', id);
    }
    return this.translator.translate(entity, ctx);
}
```

#### create (Translatable)

```typescript
async create(ctx: RequestContext, input: CreateMyEntityInput) {
    const entity = await this.translatableSaver.create({
        ctx,
        input,
        entityType: MyEntity,
        translationType: MyEntityTranslation,
        beforeSave: async (e) => {
            // Assign to current channel if ChannelAware
            await this.channelService.assignToCurrentChannel(e, ctx);
            // Set up relations here
        },
    });
    return assertFound(this.findOne(ctx, entity.id));
}
```

#### update (Translatable)

```typescript
async update(ctx: RequestContext, input: UpdateMyEntityInput) {
    const updated = await this.translatableSaver.update({
        ctx,
        input,
        entityType: MyEntity,
        translationType: MyEntityTranslation,
        beforeSave: async (e) => {
            // Update relations here if needed
        },
    });
    return assertFound(this.findOne(ctx, updated.id));
}
```

#### delete (soft delete)

```typescript
async delete(ctx: RequestContext, ids: ID[]): Promise<DeletionResponse> {
    if (ids.length === 0) {
        throw new UserInputError('error.no-ids-provided');
    }
    // Validate entities exist in channel, then soft delete
    const deleteResult = await this.connection
        .getRepository(ctx, MyEntity)
        .softDelete({ id: In(ids) });

    return {
        result: (deleteResult.affected ?? 0) > 0
            ? DeletionResult.DELETED
            : DeletionResult.NOT_DELETED,
        message: '',
    };
}
```

