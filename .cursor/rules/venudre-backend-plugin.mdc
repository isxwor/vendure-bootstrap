## GraphQL Schema (api/extension.ts)

```typescript
import { gql } from 'graphql-tag';

const common = gql`
    type MyEntity implements Node {
        id: ID!
        createdAt: DateTime!
        updatedAt: DateTime!
        title: String!
        content: String
        enabled: Boolean!
        languageCode: LanguageCode
        translations: [MyEntityTranslation!]!
    }

    type MyEntityTranslation implements Node {
        id: ID!
        createdAt: DateTime!
        updatedAt: DateTime!
        languageCode: LanguageCode!
        title: String!
        content: String!
    }

    type MyEntityList implements PaginatedList {
        items: [MyEntity!]!
        totalItems: Int!
    }

    # Empty input - Vendure auto-generates filter/sort/pagination
    input MyEntityListOptions
`;

export const shopApiExtensions = gql`
    ${common}
    extend type Query {
        myEntities(options: MyEntityListOptions): MyEntityList!
        myEntity(id: ID!): MyEntity
    }
`;

export const adminApiExtensions = gql`
    ${common}

    input MyEntityTranslationInput {
        id: ID
        languageCode: LanguageCode!
        title: String!
        content: String!
    }

    input CreateMyEntityInput {
        enabled: Boolean!
        translations: [MyEntityTranslationInput!]!
    }

    input UpdateMyEntityInput {
        id: ID!
        enabled: Boolean
        translations: [MyEntityTranslationInput!]!
    }

    extend type Mutation {
        createMyEntity(input: CreateMyEntityInput!): MyEntity!
        updateMyEntity(input: UpdateMyEntityInput!): MyEntity!
        deleteMyEntity(ids: [ID!]!): DeletionResponse!
    }

    extend type Query {
        myEntity(id: ID!): MyEntity
        myEntities(options: MyEntityListOptions): MyEntityList!
    }
`;
```

Rules:
- Extract shared types into a `common` fragment
- Types MUST implement `Node` interface (requires `id: ID!`)
- List types MUST implement `PaginatedList` interface
- `ListOptions` input MUST be empty (Vendure generates it)
- `TranslationInput` MUST have `id: ID` (optional, for updates) and `languageCode: LanguageCode!`
- Shop API: queries only. Admin API: queries + mutations + input types
- Delete mutations take `ids: [ID!]!` and return `DeletionResponse!`

