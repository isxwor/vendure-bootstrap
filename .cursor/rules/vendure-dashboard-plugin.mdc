## Detail Page (<entity>-detail.tsx)

```tsx
import { AnyRoute, useNavigate } from '@tanstack/react-router';
import {
    Button,
    DashboardRouteDefinition,
    detailPageRouteLoader,
    FormFieldWrapper,
    Input,
    Page,
    PageActionBar,
    PageActionBarRight,
    PageBlock,
    PageLayout,
    PageTitle,
    PermissionGuard,
    RichTextInput,
    Switch,
    TranslatableFormFieldWrapper,
    useDetailPage,
} from '@vendure/dashboard';
import { toast } from 'sonner';
import {
    createMyEntityMutation,
    getMyEntityDetailQuery,
    updateMyEntityMutation,
} from './<entity>.graphql';

export const myEntityDetail: DashboardRouteDefinition = {
    path: '/my-entity/$id',
    loader: detailPageRouteLoader({
        queryDocument: getMyEntityDetailQuery,
        breadcrumb: (isNew, entity) => [
            { path: '/my-entity', label: 'My Entities' },
            isNew ? 'New Entity' : entity?.title ?? '',
        ],
    }),
    component: route => <MyEntityDetailPage route={route as AnyRoute} />,
};

function MyEntityDetailPage({ route }: { route: AnyRoute }) {
    const params = route.useParams();
    const navigate = useNavigate();
    const creatingNewEntity = params.id === 'new';

    const { form, submitHandler, entity, isPending, resetForm } = useDetailPage({
        queryDocument: getMyEntityDetailQuery,
        createDocument: createMyEntityMutation,
        updateDocument: updateMyEntityMutation,
        setValuesForUpdate: entity => ({
            id: entity?.id ?? '',
            enabled: entity?.enabled ?? true,
            translations: entity.translations.map(t => ({
                id: t.id,
                languageCode: t.languageCode,
                title: t.title,
                content: t.content,
            })),
        }),
        params: { id: params.id },
        onSuccess: async data => {
            toast.success(
                creatingNewEntity
                    ? 'Successfully created entity'
                    : 'Successfully updated entity',
            );
            resetForm();
            if (creatingNewEntity) {
                await navigate({ to: `../$id`, params: { id: data.id } as any });
            }
        },
        onError: err => {
            toast.error(
                creatingNewEntity
                    ? 'Failed to create entity'
                    : 'Failed to update entity',
                {
                    description: err instanceof Error ? err.message : 'Unknown error',
                },
            );
        },
    });

    return (
        <Page pageId="my-entity-detail" form={form} submitHandler={submitHandler}>
            <PageTitle>
                {creatingNewEntity ? 'New Entity' : (entity?.title ?? '')}
            </PageTitle>
            <PageActionBar>
                <PageActionBarRight>
                    <PermissionGuard requires={['CreateMyEntity', 'UpdateMyEntity']}>
                        <Button
                            type="submit"
                            disabled={
                                !form.formState.isDirty ||
                                !form.formState.isValid ||
                                isPending
                            }
                        >
                            {creatingNewEntity ? 'Create' : 'Update'}
                        </Button>
                    </PermissionGuard>
                </PageActionBarRight>
            </PageActionBar>
            <PageLayout>
                {/* Side column - settings/toggles */}
                <PageBlock column="side" blockId="settings">
                    <FormFieldWrapper
                        control={form.control}
                        name="enabled"
                        label="Enabled"
                        description="When enabled, visible in the shop"
                        render={({ field }) => (
                            <Switch
                                checked={field.value}
                                onCheckedChange={field.onChange}
                            />
                        )}
                    />
                </PageBlock>

                {/* Main column - translatable content */}
                <PageBlock column="main" blockId="content">
                    <div className="grid gap-6 items-start mb-6">
                        <TranslatableFormFieldWrapper
                            control={form.control}
                            name="title"
                            label="Title"
                            render={({ field }) => <Input {...(field as any)} />}
                        />
                        <TranslatableFormFieldWrapper
                            control={form.control}
                            name="content"
                            label="Content"
                            render={({ field }) => <RichTextInput {...field} />}
                        />
                    </div>
                </PageBlock>
            </PageLayout>
        </Page>
    );
}
```

Rules:
- ALWAYS use `useDetailPage` hook for detail pages
- Route path MUST end with `/$id` (e.g., `/my-entity/$id`)
- Check `params.id === 'new'` to determine create vs. update mode
- Use `detailPageRouteLoader` for the route loader
- `setValuesForUpdate` maps the entity to form values - MUST include `translations` array for translatable entities
- On create success, navigate to the newly created entity: `navigate({ to: '../$id', params: { id: data.id } })`
- Use `resetForm()` after successful save
- Use `toast.success()` / `toast.error()` from `sonner` for notifications
- Use `PermissionGuard` to conditionally show the submit button

### Form Field Types

**Non-translatable fields** - use `FormFieldWrapper`:
```tsx
<FormFieldWrapper
    control={form.control}
    name="enabled"
    label="Enabled"
    render={({ field }) => <Switch checked={field.value} onCheckedChange={field.onChange} />}
/>
```

**Translatable fields** - use `TranslatableFormFieldWrapper`:
```tsx
<TranslatableFormFieldWrapper
    control={form.control}
    name="title"
    label="Title"
    render={({ field }) => <Input {...(field as any)} />}
/>
```

**Available form components from `@vendure/dashboard`:**
- `Input` - text input
- `RichTextInput` - rich text / HTML editor
- `Switch` - boolean toggle
- `Select`, `SelectContent`, `SelectItem`, `SelectTrigger`, `SelectValue` - dropdowns
- `Checkbox` - checkbox
- `DateTimeInput` - date/time picker
- `SlugInput` - auto-generated slug from another field
- `AssetGallery` - image/asset picker

### Page Layout

```tsx
<Page pageId="unique-page-id" form={form} submitHandler={submitHandler}>
    <PageTitle>Title</PageTitle>
    <PageActionBar>
        <PageActionBarRight>
            {/* Buttons */}
        </PageActionBarRight>
    </PageActionBar>
    <PageLayout>
        <PageBlock column="side" blockId="unique-block-id">
            {/* Side panel content */}
        </PageBlock>
        <PageBlock column="main" blockId="unique-block-id">
            {/* Main content */}
        </PageBlock>
    </PageLayout>
</Page>
```

- `column="side"` - right sidebar (settings, toggles, metadata)
- `column="main"` - main content area (forms, editors)
- Every `PageBlock` needs a unique `blockId`

