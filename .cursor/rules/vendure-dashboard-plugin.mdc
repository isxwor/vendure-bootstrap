## API Calls Outside of useDetailPage

When you need to make API calls manually (not via useDetailPage):

```tsx
import { api } from '@vendure/dashboard';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';

// Query
const { data, isLoading } = useQuery({
    queryKey: ['myEntities', options],
    queryFn: () => api.query(getMyEntityListQuery, { options }),
});

// Mutation
const queryClient = useQueryClient();
const { mutateAsync } = useMutation({
    mutationFn: (input: any) => api.mutate(createMyEntityMutation, { input }),
    onSuccess: () => {
        queryClient.invalidateQueries({ queryKey: ['myEntities'] });
        toast.success('Created successfully');
    },
});
```

