## List Page (<entity>-list.tsx)

```tsx
import {
    Button,
    DashboardRouteDefinition,
    ListPage,
    PageActionBarRight,
    DetailPageButton,
} from '@vendure/dashboard';
import { Link } from '@tanstack/react-router';
import { PlusIcon } from 'lucide-react';
import { getMyEntityListQuery } from './<entity>.graphql';

export const myEntityList: DashboardRouteDefinition = {
    path: '/my-entity',
    navMenuItem: {
        sectionId: 'my-section',        // Must match navSection id
        id: 'my-entity-list',
        url: '/my-entity',
        title: 'My Entities',
        requiresPermission: 'ReadMyEntity',  // Optional permission guard
    },
    loader: () => ({
        breadcrumb: 'My Entities',
    }),
    component: route => (
        <ListPage
            pageId="my-entity-list"
            title="My Entities"
            listQuery={getMyEntityListQuery}
            route={route}
            defaultVisibility={{
                id: false,
                languageCode: false,
                translations: false,
            }}
            onSearchTermChange={searchTerm => ({
                title: { contains: searchTerm },
            })}
            customizeColumns={{
                title: {
                    cell: ({ row }) => (
                        <DetailPageButton
                            id={row.original.id}
                            label={row.original.title}
                        />
                    ),
                },
            }}
        >
            <PageActionBarRight>
                <Button asChild>
                    <Link to="./new">
                        <PlusIcon className="mr-2 h-4 w-4" />
                        New Entity
                    </Link>
                </Button>
            </PageActionBarRight>
        </ListPage>
    ),
};
```

Rules:
- Use `DashboardRouteDefinition` type for route objects
- Use `<ListPage>` component (declarative, preferred approach)
- Set `defaultVisibility` to hide `id`, `languageCode`, `translations` columns
- Use `<DetailPageButton>` in the primary column to link to detail page
- `pageId` must be unique and is used to register bulk actions
- `onSearchTermChange` returns a filter object matching the entity's fields
- For faceted filters use `facetedFilters` prop
- Use `transformVariables` to modify query variables if needed

