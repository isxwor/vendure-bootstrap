## GraphQL Operations (<entity>.graphql.ts)

```tsx
import { graphql, ResultOf } from '@/gql';

// 1. Define a fragment with all fields
const myEntityFragment = graphql(`
    fragment MyEntityFragment on MyEntity {
        id
        createdAt
        updatedAt
        title
        content
        enabled
        languageCode
        translations {
            id
            languageCode
            title
            content
        }
    }
`);

// 2. List query
export const getMyEntityListQuery = graphql(
    `
        query GetMyEntityList($options: MyEntityListOptions) {
            myEntities(options: $options) {
                items {
                    ...MyEntityFragment
                }
                totalItems
            }
        }
    `,
    [myEntityFragment],
);

// 3. Detail query
export const getMyEntityDetailQuery = graphql(
    `
        query GetMyEntityDetail($id: ID!) {
            myEntity(id: $id) {
                ...MyEntityFragment
            }
        }
    `,
    [myEntityFragment],
);

// 4. Create mutation
export const createMyEntityMutation = graphql(
    `
        mutation CreateMyEntity($input: CreateMyEntityInput!) {
            createMyEntity(input: $input) {
                ...MyEntityFragment
            }
        }
    `,
    [myEntityFragment],
);

// 5. Update mutation
export const updateMyEntityMutation = graphql(
    `
        mutation UpdateMyEntity($input: UpdateMyEntityInput!) {
            updateMyEntity(input: $input) {
                ...MyEntityFragment
            }
        }
    `,
    [myEntityFragment],
);

// 6. Delete mutation
export const deleteMyEntityMutation = graphql(`
    mutation DeleteMyEntity($ids: [ID!]!) {
        deleteMyEntity(ids: $ids) {
            message
            result
        }
    }
`);

// Optional: export type for use in components
export type MyEntityFragment = ResultOf<typeof myEntityFragment>;
```

Rules:
- ALWAYS import `graphql` and `ResultOf` from `@/gql`
- ALWAYS define a fragment first, then reference it in queries/mutations using the array syntax: `graphql(\`...\`, [fragment])`
- Fragment names must match the GraphQL fragment name exactly
- Include `languageCode` and `translations` in fragments for translatable entities

