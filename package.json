{
    "name": "vendure-bootstrap",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev:server": "ts-node-dev -P ./tsconfig.json ./src/index.ts",
        "dev:worker": "ts-node-dev -P ./tsconfig.json ./src/index-worker.ts",
        "dev": "concurrently yarn:dev:*",
        "build": "./build.sh",
        "start:server": "node ./dist/src/index.js",
        "start:worker": "node ./dist/src/index-worker.js",
        "start": "concurrently yarn:start:*",
        "migration:generate": "ts-node migration.ts generate",
        "migration:run": "ts-node migration.ts run",
        "migration:revert": "ts-node migration.ts revert",
        "prepare": "husky install",
        "format": "prettier --write --ignore-unknown",
        "codegen": "graphql-codegen --config codegen.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.888.0",
        "@aws-sdk/lib-storage": "^3.888.0",
        "@types/react": "^19.1.13",
        "@vendure/admin-ui-plugin": "^3.4.2",
        "@vendure/asset-server-plugin": "3.4.2",
        "@vendure/core": "3.4.2",
        "@vendure/dashboard": "^3.4.2",
        "@vendure/email-plugin": "3.4.2",
        "@vendure/graphiql-plugin": "3.4.2",
        "@vendure/ui-devkit": "^3.4.2",
        "dotenv": "17.2.2",
        "pg": "8.16.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@graphql-codegen/cli": "^6.0.0",
        "@graphql-codegen/typescript": "^5.0.0",
        "@vendure/cli": "3.4.2",
        "concurrently": "9.2.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.6",
        "prettier": "^3.6.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "5.8.2"
    },
    "lint-staged": {
        "**/*": [
            "yarn format"
        ]
    }
}
