{
    "name": "vendure-bootstrap",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev:server": "ts-node-dev -P ./tsconfig.json ./src/index.ts",
        "dev:worker": "ts-node-dev -P ./tsconfig.json ./src/index-worker.ts",
        "dev": "concurrently bun:dev:*",
        "build": "./build.sh",
        "start:server": "node ./dist/src/index.js",
        "start:worker": "node ./dist/src/index-worker.js",
        "start": "./entrypoint.sh",
        "migration:generate": "ts-node --transpile-only migration.ts generate",
        "migration:run": "ts-node --transpile-only migration.ts run",
        "migration:revert": "ts-node --transpile-only migration.ts revert",
        "prepare": "husky install",
        "format": "prettier --write --ignore-unknown",
        "codegen": "graphql-codegen --config codegen.ts",
        "seed": "ts-node --transpile-only ./scripts/seed.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1013.0",
        "@aws-sdk/lib-storage": "^3.1013.0",
        "@types/react": "^19.2.14",
        "@vendure/asset-server-plugin": "3.6.3",
        "@vendure/core": "3.6.3",
        "@vendure/dashboard": "^3.6.3",
        "@vendure/email-plugin": "3.6.3",
        "@vendure/graphiql-plugin": "3.6.3",
        "dotenv": "17.3.1",
        "pg": "8.20.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@graphql-codegen/cli": "^6.2.1",
        "@vendure/cli": "3.6.3",
        "concurrently": "^9.2.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "5.9.3"
    },
    "lint-staged": {
        "**/*": [
            "bun format"
        ]
    }
}
